    "authorization_policy": "tools/list is session-shape discovery, not authorization. Calls still require the matching local claim, role, capability, scope, lifecycle state, and handler-specific validation."
  },
  "claim_policy": {
    "worker_claim": {
      "tool": "claim_local_assignment",
      "required_arguments": ["work_package_id"],
      "optional_arguments": ["claimed_by", "work_request_id", "repo", "base_branch", "branch", "worktree_path", "caller_id"],
      "normal_call": {"work_package_id": "<WP id>"}
    },
    "architect_claim": {
      "tool": "claim_local_architect_assignment",
      "required_arguments": ["work_request_id"],
      "optional_arguments": ["claimed_by", "architect_anchor_work_package_id", "repo", "base_branch", "phase_id", "caller_id"],
      "normal_call": {"work_request_id": "<WR id>"}
    },
    "reclaim_policy": "Replaying the same id heartbeats the current lease. Stale leases may be reclaimed with audit evidence; paused leases and another active owner are rejected.",
    "secret_policy": "Agent-facing tools, prompts, launch payloads, and docs do not require raw grant secrets, private handoff metadata, secret stores, work keys, or helper scripts."
  },
  "resources": [
    "sympp://assignment/current",
    "sympp://work-packages/{id}/context.md",
    "sympp://work-packages/{id}/task_plan.md",
    "sympp://work-packages/{id}/findings.md",
    "sympp://work-packages/{id}/progress.md",
    "sympp://work-packages/{id}/acceptance.md",
    "sympp://work-packages/{id}/review_suite.md",
    "sympp://work-packages/{id}/handoff.md"
  ],
  "tool_schemas": [
    {"name": "sympp.health", "required_arguments": [], "optional_arguments": []},
    {"name": "release_current_assignment", "required_arguments": [], "optional_arguments": ["reason"]},
    {"name": "solo_attach", "required_arguments": ["base_branch", "caller_id", "repo", "workspace_path"], "optional_arguments": ["title"]},
    {"name": "solo_show", "required_arguments": ["session_id"], "optional_arguments": []},
    {"name": "solo_list", "required_arguments": [], "optional_arguments": ["base_branch", "caller_id", "repo", "status", "workspace_path"]},
    {"name": "solo_record_task_plan", "required_arguments": ["session_id", "summary"], "optional_arguments": ["body", "idempotency_key", "payload", "status"]},
    {"name": "solo_append_progress", "required_arguments": ["session_id", "summary"], "optional_arguments": ["body", "idempotency_key", "payload", "status"]},
    {"name": "solo_append_finding", "required_arguments": ["session_id", "summary"], "optional_arguments": ["body", "idempotency_key", "payload", "severity", "status"]},
    {"name": "solo_record_decision", "required_arguments": ["decision", "session_id"], "optional_arguments": ["body", "idempotency_key", "payload", "rationale", "scope_impact"]},
    {"name": "solo_report_blocker", "required_arguments": ["session_id", "summary"], "optional_arguments": ["blocker_id", "body", "idempotency_key", "payload"]},
    {"name": "solo_resolve_blocker", "required_arguments": ["blocker_id", "resolution", "session_id"], "optional_arguments": ["body", "idempotency_key", "payload", "summary"]},
    {"name": "solo_record_validation", "required_arguments": ["result", "session_id", "summary"], "optional_arguments": ["body", "command", "evidence", "idempotency_key", "payload"]},
    {"name": "solo_pause", "required_arguments": ["session_id"], "optional_arguments": []},
    {"name": "solo_resume", "required_arguments": ["session_id"], "optional_arguments": []},
    {"name": "solo_complete", "required_arguments": ["session_id"], "optional_arguments": []},
    {"name": "solo_archive", "required_arguments": ["session_id"], "optional_arguments": []},
    {"name": "claim_local_assignment", "required_arguments": ["work_package_id"], "optional_arguments": ["base_branch", "branch", "caller_id", "claimed_by", "repo", "work_request_id", "worktree_path"]},
    {"name": "claim_local_architect_assignment", "required_arguments": ["work_request_id"], "optional_arguments": ["architect_anchor_work_package_id", "base_branch", "caller_id", "claimed_by", "phase_id", "repo"]},
    {"name": "create_work_request", "required_arguments": ["base_branch", "repo", "request_kind", "title"], "required_argument_sets": [["description"], ["human_description"]], "optional_arguments": ["claimed_by", "constraints", "created_by_kind", "created_by_name", "created_via", "creator_kind", "creator_name", "description", "human_description", "status", "workflow_mode"]},
    {"name": "add_work_request_comment", "required_arguments": ["body", "created_by", "work_request_id"], "optional_arguments": []},
    {"name": "record_work_request_operator_decision", "required_arguments": ["created_by", "decision", "rationale", "scope_impact", "work_request_id"], "optional_arguments": ["source_id"]},
    {"name": "get_current_assignment", "required_arguments": [], "optional_arguments": []},
    {"name": "read_context", "required_arguments": [], "optional_arguments": []},
    {"name": "read_task_plan", "required_arguments": [], "optional_arguments": []},
    {"name": "update_task_plan", "required_arguments": ["expected_version"], "optional_arguments": ["body", "id", "patch", "status", "title", "work_package_id"]},
    {"name": "append_finding", "required_arguments": ["body", "idempotency_key", "title"], "optional_arguments": ["id", "severity", "work_package_id"]},
    {"name": "append_progress", "required_arguments": ["idempotency_key", "summary"], "optional_arguments": ["body", "payload", "status", "work_package_id"]},
    {"name": "set_status", "required_arguments": ["expected_status", "status"], "optional_arguments": ["reason", "work_package_id"]},
    {"name": "report_blocker", "required_arguments": ["idempotency_key", "summary"], "optional_arguments": ["blocker_id", "body", "payload", "status", "work_package_id"]},
    {"name": "resolve_blocker", "required_arguments": ["blocker_id", "idempotency_key", "resolution", "summary"], "optional_arguments": ["body", "payload", "status", "work_package_id"]},
    {"name": "add_comment", "required_arguments": ["body", "target_id", "target_kind"], "optional_arguments": ["work_package_id"]},
    {"name": "list_comments", "required_arguments": ["target_id", "target_kind"], "optional_arguments": ["work_package_id"]},
    {"name": "resolve_comment", "required_arguments": ["comment_id"], "optional_arguments": ["resolution_note", "work_package_id"]},
    {"name": "create_guidance_request", "required_arguments": ["context", "idempotency_key", "question", "summary"], "optional_arguments": ["work_package_id"]},
    {"name": "read_guidance_request", "required_arguments": ["guidance_request_id"], "optional_arguments": ["work_package_id"]},
    {"name": "request_scope_expansion", "required_arguments": ["idempotency_key", "summary"], "optional_arguments": ["body", "payload", "status", "work_package_id"]},
    {"name": "attach_branch", "required_arguments": ["branch", "head_sha"], "optional_arguments": ["body", "idempotency_key", "payload", "status", "summary", "work_package_id"]},
    {"name": "attach_pr", "required_arguments": [], "optional_arguments": ["body", "head_sha", "idempotency_key", "metadata", "number", "payload", "repository", "status", "summary", "url", "work_package_id"]},
    {"name": "sync_pr", "required_arguments": ["metadata"], "optional_arguments": ["body", "head_sha", "idempotency_key", "number", "payload", "repository", "status", "summary", "url", "work_package_id"]},
    {"name": "submit_review_package", "required_arguments": ["artifacts", "head_sha", "summary", "tests"], "optional_arguments": ["acceptance_criteria_met", "body", "idempotency_key", "payload", "reviews", "status", "work_package_id"]},
    {"name": "attach_review_suite_result", "required_arguments": [], "optional_arguments": ["anchor", "head_sha", "idempotency_key", "lane", "profile", "reviewer", "round_id", "status", "suite", "summary", "verdict", "work_package_id"]},
    {"name": "mark_ready", "required_arguments": [], "optional_arguments": []},
    {"name": "create_child_work_package", "required_arguments": ["package"], "optional_arguments": []},
    {"name": "mint_child_worker_key", "required_arguments": ["work_package_id"], "optional_arguments": ["template"], "template_policy": "Optional template may set capabilities, expires_at, and claimed_by only."},
    {"name": "revoke_child_worker_key", "required_arguments": ["grant_id", "reason"], "optional_arguments": []},
    {"name": "list_work_requests", "required_arguments": [], "optional_arguments": ["status"]},
    {"name": "read_work_request", "required_arguments": ["work_request_id"], "optional_arguments": ["include_planning_scratch"]},
    {"name": "read_work_request_product_tree", "required_arguments": ["work_request_id"], "optional_arguments": ["include_planning_scratch", "view"]},
    {"name": "read_work_request_delivery_board", "required_arguments": ["work_request_id"], "optional_arguments": ["include_planning_scratch"]},
    {"name": "reconcile_work_request", "required_arguments": ["work_request_id"], "optional_arguments": ["apply", "recorded_by"]},
    {"name": "cleanup_work_request_planned_slice_runtime", "required_arguments": ["outcome", "planned_slice_id", "reason", "work_request_id"], "optional_arguments": ["abandoned_rationale", "successor_planned_slice_id", "successor_work_package_id", "superseded_reason"], "cleanup_policy": "Requires superseded or abandoned delivery evidence before cleanup. Revokes linked worker grants, releases non-paused current local claim leases, clears recoverable worker MCP session bindings for the linked WorkPackage, and records audit progress. Paused leases and fresh active AgentRun evidence fail closed."},
    {"name": "record_planned_slice_delivery", "required_arguments": ["idempotency_key", "outcome", "planned_slice_id", "work_request_id"], "optional_arguments": ["abandoned_rationale", "merge_commit_sha", "no_pr_evidence", "pr_merged_at", "pr_number", "pr_repository", "pr_url", "recorded_by", "successor_planned_slice_id", "successor_work_package_id", "superseded_reason"], "evidence_policy": "pr_merged requires pr_url and pr_merged_at; linked packages also require merge_commit_sha. completed_no_pr requires no_pr_evidence. superseded requires successor_planned_slice_id and superseded_reason. abandoned requires abandoned_rationale."},
    {"name": "revoke_planned_slice_worker_key", "required_arguments": ["grant_id", "planned_slice_id", "reason", "work_request_id"], "optional_arguments": []},
    {"name": "list_guidance_requests", "required_arguments": [], "optional_arguments": ["status", "work_package_id", "work_request_id"]},
    {"name": "answer_guidance_request", "required_arguments": ["answer", "guidance_request_id"], "optional_arguments": ["answered_by"]},
    {"name": "escalate_guidance_request", "required_arguments": ["guidance_request_id", "reason", "recommended_language"], "optional_arguments": ["decision_prompt"]},
    {"name": "set_work_request_status", "required_arguments": ["current_status", "next_status", "work_request_id"], "optional_arguments": []},
    {"name": "ask_work_request_question", "required_arguments": ["category", "question", "why_needed", "work_request_id"], "optional_arguments": ["asked_by_agent_run_id", "decision_prompt"]},
    {"name": "answer_work_request_question", "required_arguments": ["answer", "question_id", "work_request_id"], "optional_arguments": ["answered_by", "current_status", "expected_question_status"]},
    {"name": "answer_work_request_question_and_record_decision", "required_arguments": ["answer", "decision", "question_id", "rationale", "scope_impact", "source_type", "work_request_id"], "optional_arguments": ["answered_by", "created_by", "current_status", "expected_question_status", "source_id"]},
    {"name": "close_work_request_question", "required_arguments": ["question_id", "work_request_id"], "optional_arguments": ["current_status", "expected_question_status"]},
    {"name": "record_work_request_decision", "required_arguments": ["created_by", "decision", "rationale", "scope_impact", "source_type", "work_request_id"], "optional_arguments": ["source_id"], "argument_constraints": {"source_type": ["human", "architect", "operator", "ask_pro_advisory"]}},
    {"name": "add_work_request_planned_slice", "required_arguments": ["acceptance_criteria", "forbidden_file_globs", "goal", "owned_file_globs", "review_lanes", "stop_conditions", "target_base_branch", "title", "validation_steps", "work_package_kind", "work_request_id"], "optional_arguments": ["branch_pattern"], "argument_constraints": {"work_package_kind": ["quick_fix", "hotfix", "docs", "investigation", "adapter", "mcp", "skill", "hooks"]}},
    {"name": "upsert_work_request_product_plan_node", "required_arguments": ["title", "work_request_id"], "optional_arguments": ["completion_mark", "created_by", "description", "node_kind", "parent_id", "position", "product_tree_node_id"]},
    {"name": "move_work_request_planned_slice_to_product_node", "required_arguments": ["planned_slice_id", "work_request_id"], "optional_arguments": ["created_by", "position", "product_tree_node_id", "role"]},
    {"name": "approve_work_request_planned_slice", "required_arguments": ["current_status", "planned_slice_id", "work_request_id"], "optional_arguments": []},
    {"name": "skip_work_request_planned_slice", "required_arguments": ["current_status", "planned_slice_id", "work_request_id"], "optional_arguments": []},
    {"name": "mark_work_request_sliced", "required_arguments": ["current_status", "work_request_id"], "optional_arguments": []},
    {"name": "dispatch_work_request_planned_slice", "required_arguments": ["planned_slice_id", "work_request_id"], "optional_arguments": ["claimed_by"], "response_policy": "Returns worker_bootstrap for claim_local_assignment with work_package_id and optional claimed_by."},
    {"name": "prepare_work_package_worktree", "required_arguments": ["work_package_id"], "optional_arguments": ["branch", "target_repo_root"]},
    {"name": "cleanup_work_package_worktree", "required_arguments": ["work_package_id"], "optional_arguments": ["target_repo_root"]},
    {"name": "read_child_status", "required_arguments": ["work_package_id"], "optional_arguments": []},
    {"name": "approve_scope_expansion", "required_arguments": ["allowed_file_globs", "rationale", "work_package_id"], "optional_arguments": ["request_id"]},
    {"name": "read_phase_board", "required_arguments": ["phase_id"], "optional_arguments": []},
    {"name": "request_child_replan", "required_arguments": ["reason", "work_package_id"], "optional_arguments": []},
    {"name": "approve_child_ready_state", "required_arguments": ["rationale", "work_package_id"], "optional_arguments": ["request_id"]},
    {"name": "merge_child_into_phase", "required_arguments": ["merge_artifact", "work_package_id"], "optional_arguments": []},
    {"name": "split_work_package", "required_arguments": ["child_specs", "work_package_id"], "optional_arguments": []},
    {"name": "publish_phase_update", "required_arguments": ["phase_id", "update"], "optional_arguments": []}
  ]
}
