{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Symphony++ WorkPackage",
  "type": "object",
  "required": [
    "id",
    "kind",
    "title",
    "repo",
    "base_branch",
    "status"
  ],
  "properties": {
    "id": {
      "type": "string"
    },
    "kind": {
      "enum": [
        "quick_fix",
        "hotfix",
        "phase_child",
        "investigation",
        "adapter",
        "mcp",
        "skill",
        "hooks",
        "delegation",
        "docs"
      ]
    },
    "title": {
      "type": "string"
    },
    "repo": {
      "type": "string"
    },
    "base_branch": {
      "type": "string"
    },
    "branch_pattern": {
      "type": "string",
      "description": "Optional exact branch or {{placeholder}} template. Git wildcard patterns such as * are not supported."
    },
    "product_description": {
      "type": "string"
    },
    "engineering_scope": {
      "type": "string"
    },
    "acceptance_criteria": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "worktree_path": {
      "type": [
        "string",
        "null"
      ]
    },
    "status": {
      "type": "string"
    },
    "parent_id": {
      "type": [
        "string",
        "null"
      ]
    },
    "created_at": {
      "type": "string"
    },
    "updated_at": {
      "type": "string"
    }
  }
}
