{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Symphony++ AccessGrant",
  "type": "object",
  "required": [
    "id",
    "display_key",
    "secret_hash",
    "role",
    "capabilities",
    "constraints"
  ],
  "properties": {
    "id": {
      "type": "string"
    },
    "work_package_id": {
      "type": [
        "string",
        "null"
      ]
    },
    "container_scope": {
      "type": [
        "object",
        "null"
      ]
    },
    "display_key": {
      "type": "string"
    },
    "secret_hash": {
      "type": "string"
    },
    "role": {
      "enum": [
        "worker",
        "architect",
        "reviewer",
        "owner",
        "admin"
      ]
    },
    "capabilities": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "constraints": {
      "type": "object"
    },
    "expires_at": {
      "type": [
        "string",
        "null"
      ]
    },
    "claimed_at": {
      "type": [
        "string",
        "null"
      ]
    },
    "bound_agent_run_id": {
      "type": [
        "string",
        "null"
      ]
    },
    "revoked_at": {
      "type": [
        "string",
        "null"
      ]
    }
  }
}